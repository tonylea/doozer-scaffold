#!/usr/bin/env sh

# Lint staged markdown files (excluding design-docs/ and AGENTS.md)
STAGED_MD=$(git diff --cached --name-only --diff-filter=ACM | grep '\.md$' | grep -v '^design-docs/' | grep -v '^AGENTS\.md$' || true)
if [ -n "$STAGED_MD" ]; then
  echo "Running markdownlint-cli2 on staged markdown files..."
  # shellcheck disable=SC2086
  npx markdownlint-cli2 $STAGED_MD
fi

# Spell-check all staged files (cspell.json ignorePaths handles exclusions)
STAGED_SPELL=$(git diff --cached --name-only --diff-filter=ACM || true)
if [ -n "$STAGED_SPELL" ]; then
  echo "Running cspell on staged files..."
  # shellcheck disable=SC2086
  npx cspell --no-progress $STAGED_SPELL
fi

# Lint staged Go files
STAGED_GO=$(git diff --cached --name-only --diff-filter=ACM | grep '\.go$' || true)
if [ -n "$STAGED_GO" ]; then
  echo "Running golangci-lint on staged Go files..."
  golangci-lint run
fi
